# ─── App ────────────────────────────────────────────────────────────────────
# Base URL of your deployed app (used in Xendit redirect URLs and download links)
SERVER_URL=http://localhost:3000

# ─── Database (PostgreSQL — document catalog + orders + auth sessions) ────────
DATABASE_URL=postgresql://user:password@localhost:5432/docmarket

# ─── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ─── Xendit Payment Gateway ──────────────────────────────────────────────────
# Get from https://dashboard.xendit.co/settings/developers > API Keys
XENDIT_SECRET_KEY=xnd_development_...

# Get from https://dashboard.xendit.co/settings/developers > Webhooks
# The "Callback Token" shown for your webhook endpoint
XENDIT_WEBHOOK_TOKEN=your_callback_token_here

# ─── Google Drive (file storage) ─────────────────────────────────────────────
# 1. Create a folder called "DocMarket" in your Google Drive
# 2. Share it with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor
# 3. Copy the folder ID from the URL: https://drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_docmarket_root_folder_id_here

# ─── Google Sheets (customer records log) ────────────────────────────────────
# 1. Create a new Google Spreadsheet
# 2. Add a sheet tab named "Customers" (headers auto-set by npm run db:seed)
# 3. Share it with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor
# 4. Copy the Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# ─── Google Service Account (shared for Drive + Sheets) ──────────────────────
# From your Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account-name@your-project.iam.gserviceaccount.com

# The private_key field from the JSON key — keep the quotes, newlines stay as \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkq...\n-----END PRIVATE KEY-----\n"

# ─── Download Token Security ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
DOWNLOAD_TOKEN_SECRET=your-32-char-minimum-random-secret

# ─── Admin Account Seed ───────────────────────────────────────────────────────
# Run `npm run db:seed` after setting these to create the admin user
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-something-secure

# ─── Email Delivery (SMTP — optional) ────────────────────────────────────────
# If not set, download links are only shown on the success page (not emailed)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ─── Analytics (optional) ────────────────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
